# AWS credentials for the portfolio chatbot backend (server-side only; never commit real values)
# Get credentials from the AWS console (IAM → Users → Security credentials)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: session token (only needed for temporary/assumed-role credentials)
# AWS_SESSION_TOKEN=your-session-token

# AWS region where Bedrock is enabled (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock inference-profile model ID — must use the cross-region "us." prefix, NOT the raw foundation model ID
# e.g. us.anthropic.claude-haiku-4-5-20251001-v1:0  (correct)
#      anthropic.claude-haiku-4-5-20251001-v1:0      (wrong — will be blocked)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
