# Google Gemini API key for the portfolio chatbot (server-side only; get one at https://aistudio.google.com/apikey)
# Use any one of these variable names (same value):
GEMINI_API_KEY=your-key-here
# GOOGLE_API_KEY=your-key-here

# Optional: override default model (default is gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
